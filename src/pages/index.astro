---
import Layout from "../components/Layout.astro";
import { PostList } from "../components/PostList";
import {
  getBlogPosts,
  toPostListItems,
  toSearchablePosts,
} from "../utils/blogPosts";

const posts = await getBlogPosts();
const postListItems = toPostListItems(posts);
const headerPosts = toSearchablePosts(posts);
---

<Layout
  title="jeongki.dev"
  description="기술 블로그"
  ogImage="/og-image.png"
  headerPosts={headerPosts}
  isHomePage={true}
>
  <PostList client:load posts={postListItems} />
</Layout>
