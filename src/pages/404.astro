---
import Layout from "../components/Layout.astro";
import { getBlogPosts, toSearchablePosts } from "../utils/blogPosts";
import styles from "./404.module.css";

const posts = await getBlogPosts();
const headerPosts = toSearchablePosts(posts);

const latestPost = posts[0];
---

<Layout
  title="404 | jeongki.dev"
  description="요청한 페이지를 찾을 수 없습니다."
  robots="noindex, nofollow"
  headerPosts={headerPosts}
>
  <section class={styles.page}>
    <div class={styles.shell}>
      <p class={styles.eyebrow}>Error 404</p>
      <h1 class={styles.title}>찾고 있는 페이지가 사라졌거나 이동했어요.</h1>
      <p class={styles.description}>
        주소가 바뀌었거나 아직 공개되지 않은 페이지일 수 있습니다. 홈으로 돌아가거나
        최신 글부터 다시 둘러보세요.
      </p>

      <div class={styles.actions}>
        <a href="/" class={styles.primaryAction}>
          Go home
        </a>
        {latestPost && (
          <a href={`/posts/${latestPost.id}`} class={styles.secondaryAction}>
            Read latest post
          </a>
        )}
      </div>
    </div>
  </section>
</Layout>
