---
import { getCollection, render } from "astro:content";
import GiscusComments from "../../components/GiscusComments.astro";
import Layout from "../../components/Layout.astro";
import { getBlogPosts, toSearchablePosts } from "../../utils/blogPosts";
import { formatDate } from "../../utils/formatDate";
import { getReadMinutes } from "../../utils/getReadMinutes";
import styles from "./post.module.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const readMinutes = getReadMinutes(post.body || "");
const headerPosts = toSearchablePosts(await getBlogPosts());
const pageTitle = `${post.data.title} | jeongki.dev`;
---

<Layout
  title={pageTitle}
  description={post.data.description}
  ogImage={post.data.heroImage ?? "/og-image.png"}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  author={post.data.author}
  tags={post.data.tags}
  headerPosts={headerPosts}
>
  <section class={styles.page}>
    <article class={styles.article}>
      <div class={styles.meta}>
        <span class={styles.tag}>{post.data.tags[0]}</span>
        <span class={styles.metaText}>
          {formatDate(post.data.pubDate)}
          • {readMinutes} min read
        </span>
      </div>

      <h1 class={styles.title}>{post.data.title}</h1>

      {post.data.heroImage && (
        <div class={styles.hero}>
          <img
            src={post.data.heroImage}
            alt={post.data.title}
            class={styles.heroImage}
            width="1200"
            height="840"
            decoding="async"
          />
        </div>
      )}

      <div class={styles.content}>
        <div class={styles.prose}><Content /></div>

        <p class={styles.author}>
          Written by <a href="#comments">{post.data.author}</a>
        </p>

        <section id="comments" class={styles.comments}>
          <h2 class={styles.commentsTitle}>Comments</h2>
          <GiscusComments />
        </section>
      </div>
    </article>
  </section>
</Layout>
