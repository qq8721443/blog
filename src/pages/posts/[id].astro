---
import { getCollection, render } from "astro:content";
import GiscusComments from "../../components/GiscusComments.astro";
import Layout from "../../components/Layout.astro";
import { getBlogPosts, toSearchablePosts } from "../../utils/blogPosts";
import { toPostDetailViewModel } from "../../utils/postDetail";
import styles from "./post.module.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const headerPosts = toSearchablePosts(await getBlogPosts());
const detail = toPostDetailViewModel(post);
---

<Layout
  title={detail.pageTitle}
  description={detail.description}
  ogImage={detail.ogImage}
  type="article"
  publishedTime={detail.publishedTime}
  author={detail.author}
  tags={detail.tags}
  headerPosts={headerPosts}
>
  <section class={styles.page}>
    <article class={styles.article}>
      <div class={styles.meta}>
        {detail.primaryTag && <span class={styles.tag}>{detail.primaryTag}</span>}
        <span class={styles.metaText}>
          {detail.formattedDate}
          • {detail.readMinutes} min read
        </span>
      </div>

      <h1 class={styles.title}>{detail.title}</h1>

      {detail.heroImage && (
        <div class={styles.hero}>
          <img
            src={detail.heroImage}
            alt={detail.heroAlt}
            class={styles.heroImage}
            width="1200"
            height="840"
            decoding="async"
          />
        </div>
      )}

      <div class={styles.content}>
        <div class={styles.prose}><Content /></div>

        <p class={styles.author}>
          Written by <a href="#comments">{detail.author}</a>
        </p>

        <section id="comments" class={styles.comments}>
          <h2 class={styles.commentsTitle}>Comments</h2>
          <GiscusComments />
        </section>
      </div>
    </article>
  </section>
</Layout>
